---
import '../main.css'
import AppHeader from '../components/AppHeader.vue'
import AppModal from '../components/AppModal.vue'
import HeroSection from '../components/HeroSection.vue'
import FeaturesSection from '../components/FeaturesSection.astro'
import CtaSection from '../components/CtaSection.astro'
import TestimonialsSection from '../components/TestimonialsSection.astro'
import IntegrationsSection from '../components/IntegrationsSection.vue'
import PricingSection from '../components/PricingSection.vue'
import ResaleSection from '../components/ResaleSection.astro'
import FaqSection from '../components/FaqSection.vue'
import Footer from '../components/Footer.astro'
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>waTidy - CRM para WhatsApp | Extensão Chrome para Vendas</title>
    <meta
      name="description"
      content="waTidy é o CRM para WhatsApp mais completo do Brasil. Gerencie leads, automatize atendimentos e aumente suas vendas com a extensão para Chrome. Mais de 250.000 usuários."
    />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://watidy.com.br/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content="https://watidy.com.br/" />
    <meta property="og:site_name" content="waTidy" />
    <meta property="og:title" content="waTidy - CRM para WhatsApp | Extensão Chrome para Vendas" />
    <meta
      property="og:description"
      content="waTidy é o CRM para WhatsApp mais completo do Brasil. Gerencie leads, automatize atendimentos e aumente suas vendas. Mais de 250.000 usuários."
    />
    <meta property="og:image" content="https://watidy.com.br/imgs/logo.webp" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="waTidy - CRM para WhatsApp | Extensão Chrome para Vendas" />
    <meta
      name="twitter:description"
      content="waTidy é o CRM para WhatsApp mais completo do Brasil. Gerencie leads, automatize atendimentos e aumente suas vendas. Mais de 250.000 usuários."
    />
    <meta name="twitter:image" content="https://watidy.com.br/imgs/logo.webp" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Preload crítico (LCP) -->
    <link rel="preload" href="/Thumbnail%20Youtube.png" as="image" fetchpriority="high" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://watidy.com.br/#organization",
          "name": "waTidy",
          "url": "https://watidy.com.br",
          "logo": "https://watidy.com.br/imgs/logo.webp",
          "sameAs": [
            "https://www.instagram.com/watidy_crm/",
            "https://www.youtube.com/@watidy",
            "https://www.tiktok.com/@watidyapp"
          ],
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+55-31-2942-4122",
            "contactType": "customer support",
            "availableLanguage": "Portuguese"
          }
        },
        {
          "@type": "SoftwareApplication",
          "@id": "https://watidy.com.br/#software",
          "name": "waTidy",
          "applicationCategory": "BusinessApplication",
          "operatingSystem": "Chrome, Edge, Opera",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "BRL",
            "description": "Plano gratuito disponível"
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.8",
            "reviewCount": "250000"
          },
          "description": "CRM completo para WhatsApp Web. Gerencie leads, automatize atendimentos, kanban de vendas e muito mais. Extensão para Google Chrome.",
          "url": "https://watidy.com.br",
          "publisher": {
            "@id": "https://watidy.com.br/#organization"
          }
        },
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "Como usar a ferramenta?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "A ferramenta pode ser usada como uma extensão do Google Chrome, Microsoft Edge ou Opera. Funciona tanto no Windows quanto no MAC."
              }
            },
            {
              "@type": "Question",
              "name": "Preciso de mais atendentes, como faço?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "A extensão do WhatsApp Web te permite conectar até 4 atendentes. Cada usuário precisa de 1 licença, que pode ser a Free ou a Premium."
              }
            },
            {
              "@type": "Question",
              "name": "É seguro usar o waTidy?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Sim, a ferramenta passou por um processo rigoroso antes de ser publicada no repositório do Google. Para estar lá, é necessário passar por um longo processo de auditoria e controle do código-fonte."
              }
            },
            {
              "@type": "Question",
              "name": "O waTidy armazena minhas informações de contato?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Não. Os dados transacionados no waTidy ficam armazenados localmente na sua máquina. Não possuímos servidores de armazenamento."
              }
            },
            {
              "@type": "Question",
              "name": "Como funciona o suporte?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Se você precisar entrar em contato conosco, nos chame pelo whatsapp 3129424122. Atendemos em horário comercial."
              }
            }
          ]
        }
      ]
    }
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>((w,d,s,l,i)=> {w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://servertest.watidy.com.br/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NKDNR3WB');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-P3L8N7GN"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <AppModal client:idle />
    <div class="min-h-screen bg-white flex flex-col font-sans relative scroll-smooth z-0">
      <AppHeader client:idle />
      <main class="z-20">
        <HeroSection client:load />
        <FeaturesSection />
        <CtaSection />
        <TestimonialsSection />
        <IntegrationsSection client:visible />
        <PricingSection client:idle />
        <ResaleSection />
        <FaqSection client:visible />
      </main>
      <Footer />
    </div>
  </body>
</html>
